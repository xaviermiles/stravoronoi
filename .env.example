# Public Mapbox access token (pk.*) from https://account.mapbox.com/access-tokens/
MAPBOX_TOKEN=

# ---------------------------------------------------------------------------
# Strava application credentials, from https://www.strava.com/settings/api
# Set that page's "Authorization Callback Domain" to: localhost
# ---------------------------------------------------------------------------
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# STRAVA_REFRESH_TOKEN — long-lived token used on page load to mint a
# short-lived (6h) access token. It does not expire unless you revoke access,
# so this is a one-time setup. Get it once with the manual OAuth flow below.
#
# 1) Authorize your app: open this URL in a browser (replace YOUR_CLIENT_ID),
#    click "Authorize", then copy the `code` value out of the redirected URL
#    (the http://localhost/... page will fail to load — that's expected):
#
#      https://www.strava.com/oauth/authorize?client_id=YOUR_CLIENT_ID&response_type=code&redirect_uri=http://localhost/exchange_token&approval_prompt=force&scope=activity:read_all
#
#    Use scope=activity:read for public runs only, or activity:read_all to also
#    include private ones. The redirect looks like:
#      http://localhost/exchange_token?state=&code=THE_CODE&scope=read,activity:read_all
#
# 2) Exchange that (single-use, short-lived) code for tokens. In PowerShell:
#
#      $body = @{
#        client_id     = "YOUR_CLIENT_ID"
#        client_secret = "YOUR_CLIENT_SECRET"
#        code          = "THE_CODE"
#        grant_type    = "authorization_code"
#      }
#      Invoke-RestMethod -Uri "https://www.strava.com/oauth/token" -Method Post -Body $body
#
# 3) Copy the `refresh_token` field from the JSON response into the value below.
#    If you get {"errors":[{"code":"invalid"}]}, the code expired — redo step 1
#    for a fresh code and immediately rerun step 2.
# ---------------------------------------------------------------------------
STRAVA_REFRESH_TOKEN=
